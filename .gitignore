# ซ่อนไฟล์ใดไฟล์หนึ่งแบบเจาะจง (พิมพ์ชื่อไฟล์เต็มๆ)
secrets.php
config/db_connect.php
e_borrow.sql
.env


# ซ่อนทั้งโฟลเดอร์ (ใส่เครื่องหมาย / ต่อท้าย)
# Note: ใช้ /* แทน / เพื่อให้ negate `!.../.htaccess` ทำงาน
# (git ไม่ recurse เข้า dir ที่ ignore ทั้งก้อน)
e_Borrow/uploads/*
!e_Borrow/uploads/.htaccess
node_modules/
# vendor/ ไม่ได้ ignore — commit เข้า repo เพราะ server ไม่มี Composer

# ซ่อนไฟล์ทุกตัวที่มีนามสกุลตามที่กำหนด (ใช้เครื่องหมายดอกจัน *)
*.sql
*.log

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# Staging Sandbox
ux_staging/

# Tailwind CLI binary (compile locally, do not commit)
tailwindcss
tailwindcss-*
