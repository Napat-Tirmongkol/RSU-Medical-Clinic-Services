# rsu-clinic/.htaccess

Options -Indexes

# ─── Security Headers ─────────────────────────────────────────────────────
<IfModule mod_headers.c>
    # ป้องกัน Clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # ป้องกัน MIME sniffing
    Header always set X-Content-Type-Options "nosniff"

    # บังคับ HTTPS (HSTS) — 1 ปี
    # NOTE: เมื่อโดเมนพร้อม submit https://hstspreload.org ให้เพิ่ม "; preload"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # XSS Protection (browsers เก่า)
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions-Policy — disable browser features ที่ระบบไม่ได้ใช้
    # (Phase 7 audit High: ลด attack surface ของ Feature APIs)
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), accelerometer=(), gyroscope=(), magnetometer=(), interest-cohort=()"

    # Cross-Origin Opener/Resource Policy — กัน Spectre-class attacks ระหว่าง origin
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-site"

    # Remove server/PHP version fingerprints (defense-in-depth).
    # expose_php=Off ใน .user.ini จัดการที่ฝั่ง PHP-FPM แล้ว; ตรงนี้กันชั้นเพิ่ม
    # สำหรับ mod_php / reverse proxy ที่อาจไม่อ่าน .user.ini
    Header always unset X-Powered-By
    Header unset X-Powered-By
    Header always unset Server
    Header unset Server

    # Content Security Policy — อนุญาต CDN ที่ระบบใช้อยู่
    # TODO: ลบ 'unsafe-inline' จาก script-src ผ่าน CSP nonce migration (tracked epic)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://cdn.onesignal.com https://cdn.tailwindcss.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com https://cdn.tailwindcss.com; font-src 'self' https://cdnjs.cloudflare.com https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://onesignal.com; frame-src 'self';"
</IfModule>

# ─── Force HTTPS ──────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Enable Rewrite
RewriteEngine On

# ─── Redirects (Legacy Paths) ───────────────────────────────────────────
RewriteRule ^archive/e_Borrow/login\.php$ e_Borrow/login.php [R=301,L,NC]
RewriteRule ^archive/line_api/(.*)$ line_api/$1 [R=301,L,NC]

# Suppress favicon.ico 404 — return empty 204 No Content
RewriteRule ^favicon\.ico$ - [R=204,L]

# ─── Session Security (PHP) ───────────────────────────────────
<IfModule mod_php.c>
    php_flag session.cookie_secure   On
    php_flag session.cookie_httponly On
    php_value session.cookie_samesite Lax
</IfModule>

# ─── Upload Limits (Insurance Sync Hub + Gold Card Bulk Import) ───────
# Note: PHP-FPM ใช้ค่าจาก .user.ini แทน — block นี้ใช้เฉพาะกรณี mod_php
<IfModule mod_php.c>
    php_value upload_max_filesize 100M
    php_value post_max_size       256M
    php_value max_file_uploads    500
    php_value max_input_vars      10000
    php_value max_execution_time  300
    php_value memory_limit        512M
</IfModule>
<IfModule mod_php8.c>
    php_value upload_max_filesize 100M
    php_value post_max_size       256M
    php_value max_file_uploads    500
    php_value max_input_vars      10000
    php_value max_execution_time  300
    php_value memory_limit        512M
</IfModule>

# DirectoryIndex
DirectoryIndex index.php index.html

# ─── Custom Error Pages ───────────────────────────────────────
ErrorDocument 400 /rsu-clinic/errors/404.php
ErrorDocument 403 /rsu-clinic/errors/403.php
ErrorDocument 404 /rsu-clinic/errors/404.php
ErrorDocument 500 /rsu-clinic/errors/500.php
ErrorDocument 502 /rsu-clinic/errors/500.php
ErrorDocument 503 /rsu-clinic/errors/503.php
ErrorDocument 504 /rsu-clinic/errors/503.php
