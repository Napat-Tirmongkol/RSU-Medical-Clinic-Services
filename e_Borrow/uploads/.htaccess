# Block script execution under e_Borrow/uploads/ (covers slips/, equipment_images/, attachments/).
# Closes the RCE primitive in direct_payment_process.php / record_payment_process.php /
# add_equipment_type_process.php / edit_equipment_type_process.php / request_borrow_process.php
# where extension is taken from user-supplied filename without whitelist.
<FilesMatch "\.(php|phtml|phar|pl|py|jsp|asp|aspx|sh|cgi|js\.php)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Deny from all
    </IfModule>
</FilesMatch>

# Disable directory listing
Options -Indexes

# Disable any handlers that might run files based on extension
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
RemoveHandler .php .phtml .phar .pl .py
RemoveType .php .phtml .phar .pl .py
