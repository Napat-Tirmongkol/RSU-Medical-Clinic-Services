<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <!-- Redirect Legacy e_Borrow Login -->
                <rule name="RedirectLegacyLogin" stopProcessing="true">
                    <match url="^archive/e_Borrow/login\.php$" />
                    <action type="Redirect" url="e_Borrow/login.php" redirectType="Permanent" />
                </rule>

                <!-- Force HTTPS -->
                <rule name="ForceHTTPS" stopProcessing="true">
                    <match url="(.*)" />
                    <conditions>
                        <add input="{HTTPS}" pattern="off" ignoreCase="true" />
                    </conditions>
                    <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
                </rule>
            </rules>
        </rewrite>

        <!--
            Custom error pages
            - errorMode="Custom"          : ใช้ custom error สำหรับทุก request (ไม่ใช่แค่ localhost)
            - existingResponse="Replace"  : บังคับ override IIS default แม้จะมี response เดิม
            - responseMode="ExecuteURL"   : run PHP page (ไม่ใช่ static redirect)
        -->
        <httpErrors errorMode="Custom" existingResponse="Replace">
            <remove statusCode="400" />
            <remove statusCode="403" />
            <remove statusCode="404" />
            <remove statusCode="500" />
            <remove statusCode="502" />
            <remove statusCode="503" />
            <remove statusCode="504" />
            <error statusCode="400" path="/e-campaignv2/errors/404.php" responseMode="ExecuteURL" />
            <error statusCode="403" path="/e-campaignv2/errors/403.php" responseMode="ExecuteURL" />
            <error statusCode="404" path="/e-campaignv2/errors/404.php" responseMode="ExecuteURL" />
            <error statusCode="500" path="/e-campaignv2/errors/500.php" responseMode="ExecuteURL" />
            <error statusCode="502" path="/e-campaignv2/errors/500.php" responseMode="ExecuteURL" />
            <error statusCode="503" path="/e-campaignv2/errors/503.php" responseMode="ExecuteURL" />
            <error statusCode="504" path="/e-campaignv2/errors/503.php" responseMode="ExecuteURL" />
        </httpErrors>

        <!-- Security headers -->
        <httpProtocol>
            <customHeaders>
                <add name="X-Frame-Options" value="SAMEORIGIN" />
                <add name="X-Content-Type-Options" value="nosniff" />
                <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
            </customHeaders>
        </httpProtocol>

        <!-- Default document -->
        <defaultDocument>
            <files>
                <clear />
                <add value="index.php" />
                <add value="index.html" />
            </files>
        </defaultDocument>
    </system.webServer>
</configuration>
